                </mapping>
                <mapping>
                    <value>5</value>
                    <newvalue>activating</newvalue>
                </mapping>
                <mapping>
                    <value>6</value>
                    <newvalue>deactivating</newvalue>
                </mapping>
            </mappings>
        </value_map>
        <value_map>
            <name>Unit File State</name>
            <mappings>
                <mapping>
                    <value>0</value>
