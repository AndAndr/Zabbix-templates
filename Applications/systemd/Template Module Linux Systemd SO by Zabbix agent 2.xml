                </mapping>
                <mapping>
                    <value>3</value>
                    <newvalue>linked</newvalue>
                </mapping>
                <mapping>
                    <value>4</value>
                    <newvalue>linked-runtime</newvalue>
                </mapping>
                <mapping>
                    <value>5</value>
                    <newvalue>masked</newvalue>
                </mapping>
                <mapping>
                    <value>6</value>
